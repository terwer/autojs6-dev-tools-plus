<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:App.Avalonia.ViewModels"
             x:Class="App.Avalonia.Views.Panels.WidgetModeSidebar"
             x:Name="WidgetSidebarRoot"
             x:DataType="vm:MainWindowViewModel">
  <StackPanel Spacing="12">
    <Border Classes="surface-card section-card">
      <StackPanel Spacing="12">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
          <TextBlock Classes="title-lg" VerticalAlignment="Center" Text="节点树"/>
          <Button Grid.Column="1" Classes.base-action="True" Classes.primary-action="True" Content="拉取 UI 树" Command="{Binding PullUiTreeCommand}" IsEnabled="{Binding CanPullUiTree}"/>
        </Grid>

        <TextBox Classes="panel-input" PlaceholderText="搜索 class / text / desc / resource-id" Text="{Binding WidgetTreeSearchText}"/>
        <TextBlock Classes="caption-muted" Text="{Binding WidgetTreeSummaryText}"/>

        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="14" Padding="12" MinHeight="220">
          <Grid>
            <ListBox ItemsSource="{Binding WidgetNodes}"
                     SelectedItem="{Binding SelectedWidgetTreeNode, Mode=TwoWay}"
                     IsVisible="{Binding HasWidgetNodes}">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:WidgetTreeNodeViewModel">
                  <Grid Margin="{Binding Indent}" ColumnDefinitions="Auto,*" ColumnSpacing="6">
                    <Button Grid.Column="0"
                            Classes="base-action"
                            Padding="6,0"
                            MinWidth="24"
                            Content="{Binding ExpandGlyph}"
                            IsVisible="{Binding HasChildren}"
                            Command="{Binding #WidgetSidebarRoot.DataContext.ToggleWidgetNodeExpansionCommand}"
                            CommandParameter="{Binding}"/>
                    <Border Grid.Column="1" Padding="2,4">
                      <StackPanel Spacing="1">
                        <TextBlock Text="{Binding Title}"/>
                        <TextBlock Classes="caption-soft" Text="{Binding Subtitle}"/>
                      </StackPanel>
                    </Border>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock IsVisible="{Binding IsWidgetTreeEmpty}" Text="尚未加载 UI 树。进入控件模式后，点击“拉取 UI 树”即可在这里查看节点结构。" TextWrapping="Wrap"/>
          </Grid>
        </Border>
      </StackPanel>
    </Border>

    <Border Classes="surface-card section-card">
      <StackPanel Spacing="12">
        <TextBlock Classes="title-lg" Text="属性与代码动作"/>

        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="类名"/>
          <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PropertyClassName}"/>
          <TextBlock Grid.Row="1" Grid.Column="0" Text="文本"/>
          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PropertyText}"/>
          <TextBlock Grid.Row="2" Grid.Column="0" Text="ID"/>
          <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PropertyId}"/>
        </Grid>

        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Bounds"/>
          <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PropertyBounds}"/>
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Package"/>
          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PropertyPackage}"/>
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Clickable"/>
          <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PropertyClickable}"/>
        </Grid>

        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="14" Padding="12">
          <TextBlock Text="{Binding WidgetSelectionHint}" TextWrapping="Wrap"/>
        </Border>

        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="14" Padding="12">
          <TextBlock Text="{Binding SelectorValidationReport}" TextWrapping="Wrap"/>
        </Border>

        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="14" Padding="12">
          <TextBlock Text="{Binding AlignmentValidationReport}" TextWrapping="Wrap"/>
        </Border>

        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
          <Button Grid.Column="0" Classes.base-action="True" Content="复制坐标" Command="{Binding CopySelectedWidgetCoordinatesCommand}" IsEnabled="{Binding CanCopySelectedWidgetCoordinates}"/>
          <Button Grid.Column="1" Classes.base-action="True" Content="复制 XPath" Command="{Binding CopySelectedWidgetXPathCommand}" IsEnabled="{Binding CanCopySelectedWidgetXPath}"/>
          <Button Grid.Row="1" Grid.Column="0" Classes.base-action="True" Content="复制 UiSelector" Command="{Binding CopySelectedWidgetSelectorCommand}" IsEnabled="{Binding CanCopySelectedWidgetSelector}"/>
          <Button Grid.Row="1" Grid.Column="1" Classes.base-action="True" Classes.primary-action="True" Content="查看代码" Command="{Binding OpenCodePreviewCommand}" IsEnabled="{Binding CanGenerateCode}"/>
        </Grid>

        <Button Classes="base-action"
                Content="验证选择器"
                Command="{Binding ValidateSelectedWidgetSelectorCommand}"
                IsEnabled="{Binding CanValidateSelectedWidgetSelector}"/>

        <Button Classes="base-action"
                Content="验证坐标对齐"
                Command="{Binding ValidateCoordinateAlignmentCommand}"
                IsEnabled="{Binding CanValidateCoordinateAlignment}"/>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>


