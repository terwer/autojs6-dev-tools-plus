<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:App.Avalonia.ViewModels"
             x:Class="App.Avalonia.Views.Panels.ImageModeSidebar"
             x:DataType="vm:MainWindowViewModel">
  <StackPanel Spacing="12">
    <Border Classes="surface-card section-card">
      <StackPanel Spacing="14">
        <TextBlock Classes="title-lg" Text="来源"/>

        <Grid ColumnDefinitions="Auto,Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
          <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="模板"/>
          <RadioButton Grid.Row="0" Grid.Column="1" GroupName="TemplateSource" IsChecked="{Binding IsTemplateSourceCurrent}" Content="当前"/>
          <RadioButton Grid.Row="0" Grid.Column="2" GroupName="TemplateSource" IsChecked="{Binding IsTemplateSourceBrowse}" Content="浏览"/>
          <Button Grid.Row="0" Grid.Column="3" Classes="base-action" Content="浏览" IsEnabled="False"/>

          <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="截图"/>
          <RadioButton Grid.Row="1" Grid.Column="1" GroupName="ScreenshotSource" IsChecked="{Binding IsScreenshotSourceCurrent}" Content="当前"/>
          <RadioButton Grid.Row="1" Grid.Column="2" GroupName="ScreenshotSource" IsChecked="{Binding IsScreenshotSourceBrowse}" Content="浏览"/>
          <Button Grid.Row="1" Grid.Column="3" Classes="base-action" Content="浏览" IsEnabled="False"/>
        </Grid>

        <TextBlock Classes="caption-muted" Text="当前截图与模板来源将在 4.5 主工作流接入后生效。" TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <Border Classes="surface-card section-card">
      <StackPanel Spacing="14">
        <TextBlock Classes="title-lg" Text="操作"/>

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
          <TextBox Grid.Column="0" Classes="panel-input" Text="{Binding OperationInputText}" IsReadOnly="True"/>
          <Button Grid.Column="1" Classes="base-action" Content="复制" IsEnabled="False"/>
        </Grid>

        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
          <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="阈值"/>
          <Slider Grid.Column="1" Minimum="0.5" Maximum="0.95" Value="{Binding MatchThreshold}"/>
          <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding MatchThreshold, StringFormat={}{0:F2}}"/>
        </Grid>

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
          <CheckBox Grid.Column="0" Classes="inline-check" IsChecked="{Binding SearchAllScreen}" Content="全图搜索（默认优先使用区域搜索）"/>
          <Button Grid.Column="1" Classes="base-action primary-action" Content="执行测试" IsEnabled="{Binding ArePrimaryWorkflowActionsEnabled}"/>
        </Grid>

        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="14" Padding="12">
          <TextBlock Text="{Binding MatchResultSummary}" TextWrapping="Wrap"/>
        </Border>

        <TextBlock Classes="caption-muted" Text="{Binding TemplateDirectoryText}" TextWrapping="Wrap"/>
        <TextBox Classes="panel-input" PlaceholderText="模板名（留空自动生成）" Text="{Binding TemplateName}"/>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>

