<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:App.Avalonia.ViewModels"
        xmlns:panels="using:App.Avalonia.Views.Panels"
        xmlns:controls="using:App.Avalonia.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="App.Avalonia.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1500"
        Height="900"
        MinWidth="1280"
        MinHeight="760"
        Title="{Binding WindowTitle}"
        Icon="/Assets/avalonia-logo.ico"
        Classes="workbench-window">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="14" Margin="14">
    <Border Grid.Row="0" Classes="surface-card section-card" Padding="16,14">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
        <StackPanel Spacing="4">
          <TextBlock Classes="title-xl" Text="AutoJS6 可视化工作台"/>
          <TextBlock Classes="caption-muted" Text="{Binding CurrentDeviceText}"/>
        </StackPanel>

        <Border Grid.Column="1"
                HorizontalAlignment="Center"
                Background="#EEF1F5"
                BorderBrush="{DynamicResource BorderBrushNormal}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="4">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Button Classes.base-action="True"
                    Classes.segmented-toggle="True"
                    Classes.active="{Binding IsImageMode}"
                    Content="图像模式"
                    Command="{Binding SwitchToImageModeCommand}"/>
            <Button Classes.base-action="True"
                    Classes.segmented-toggle="True"
                    Classes.active="{Binding IsWidgetMode}"
                    Content="控件模式"
                    Command="{Binding SwitchToWidgetModeCommand}"/>
          </StackPanel>
        </Border>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
          <Button Classes.base-action="True" Classes.primary-action="True" Content="截屏" Command="{Binding CaptureScreenshotCommand}" IsEnabled="{Binding CanCaptureScreenshot}"/>
          <Button Classes.base-action="True" Content="载入图片" Command="{Binding LoadScreenshotImageCommand}"/>
          <Button Classes.base-action="True" Content="查看代码" Command="{Binding OpenCodePreviewCommand}" IsEnabled="{Binding CanGenerateCode}"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="220,*,320" ColumnSpacing="14">
      <Grid Grid.Column="0" RowDefinitions="Auto,*" RowSpacing="12">
        <Border Grid.Row="0" Classes="surface-card section-card">
          <UniformGrid Columns="3" Rows="1">
            <Button Classes.base-action="True" Content="刷新" Command="{Binding RefreshDevicesCommand}" Margin="0,0,8,0"/>
            <Button Classes.base-action="True" Content="扫描" Command="{Binding RefreshDevicesCommand}" Margin="4,0"/>
            <Button Classes.base-action="True" Content="无线" IsEnabled="False" Margin="8,0,0,0"/>
          </UniformGrid>
        </Border>

        <Border Grid.Row="1" Classes="surface-card section-card">
          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
            <TextBlock Classes="title-lg" Text="设备列表"/>
            <TextBlock Grid.Row="1" Classes="caption-muted" Text="已连接设备将在这里显示，点击即可设为当前工作目标。" TextWrapping="Wrap"/>
            <Grid Grid.Row="2">
              <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Devices}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DeviceListItemViewModel">
                      <Button Classes.base-action="True"
                              Classes.device-item="True"
                              Classes.active="{Binding IsSelected}"
                              Margin="0,0,0,10"
                              Command="{Binding #RootWindow.DataContext.SelectDeviceCommand}"
                              CommandParameter="{Binding}">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="6">
                          <TextBlock Grid.Row="0" Grid.Column="0" FontSize="15" FontWeight="SemiBold" Text="{Binding Serial}"/>
                          <TextBlock Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Text="{Binding State}"/>
                          <TextBlock Grid.Row="1" Grid.Column="0" Classes="caption-muted" Text="{Binding Model}"/>
                          <TextBlock Grid.Row="1" Grid.Column="1" Classes="caption-muted" Text="{Binding ConnectionType}"/>
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
              <TextBlock IsVisible="{Binding IsDeviceListEmpty}"
                         Classes="caption-muted"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         Text="尚未发现设备。"
                         TextWrapping="Wrap"/>
            </Grid>
          </Grid>
        </Border>
      </Grid>

      <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" RowSpacing="12">
        <Border Grid.Row="0" Classes="surface-card section-card">
          <Grid>
            <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsImageMode}">
              <Button Classes.base-action="True" Content="适应窗口" IsEnabled="False"/>
              <Button Classes.base-action="True" Content="原图 1:1" IsEnabled="False"/>
              <Button x:Name="RotateImageButton" Classes.base-action="True" Content="旋转 90°" IsEnabled="{Binding HasCanvasContent}"/>
              <Button Classes.base-action="True"
                      Content="{Binding CropButtonText}"
                      Command="{Binding ToggleCropModeCommand}"
                      IsEnabled="{Binding HasCanvasContent}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsWidgetMode}">
              <Button Classes.base-action="True" Content="拉取 UI 树" Command="{Binding PullUiTreeCommand}" IsEnabled="{Binding CanPullUiTree}"/>
              <Button x:Name="RotateWidgetButton" Classes.base-action="True" Content="旋转 90°" IsEnabled="{Binding HasCanvasContent}"/>
              <CheckBox Classes="inline-check" VerticalAlignment="Center" IsChecked="{Binding IsWidgetBoundsVisible}" Content="显示控件框"/>
            </StackPanel>
          </Grid>
        </Border>

        <Border Grid.Row="1" Classes="surface-card section-card stage-shell">
          <Grid>
            <controls:WorkbenchCanvasControl x:Name="WorkbenchCanvas"
                                             CanvasBitmap="{Binding CanvasBitmap}"
                                             OverlayRects="{Binding CanvasOverlays}"
                                             ShowOverlay="{Binding IsWidgetBoundsVisible}"
                                             IsCropModeEnabled="{Binding IsCropModeEnabled}"
                                             CropRegion="{Binding CropRegion, Mode=TwoWay}"/>
            <Border Classes="empty-hint-card"
                    Width="320"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsCanvasEmpty}">
              <StackPanel Spacing="14" HorizontalAlignment="Center">
                <TextBlock Classes="title-xl" HorizontalAlignment="Center" Text="{Binding CanvasPlaceholderTitle}"/>
                <TextBlock Classes="caption-muted"
                           Width="240"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Text="{Binding CanvasPlaceholderDescription}"/>
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                  <Button Classes.base-action="True" Classes.primary-action="True" Content="立即截屏" Command="{Binding CaptureScreenshotCommand}" IsEnabled="{Binding CanCaptureScreenshot}"/>
                  <Button Classes.base-action="True" Content="载入图片" Command="{Binding LoadScreenshotImageCommand}"/>
                </StackPanel>
              </StackPanel>
            </Border>
          </Grid>
        </Border>

        <Border Grid.Row="2" Classes="surface-card section-card status-strip">
          <TextBlock Text="{Binding WorkspaceStatusLine}"/>
        </Border>
      </Grid>

      <Grid Grid.Column="2">
        <panels:ImageModeSidebar IsVisible="{Binding IsImageMode}"/>
        <panels:WidgetModeSidebar IsVisible="{Binding IsWidgetMode}"/>
      </Grid>
    </Grid>

    <Border Grid.Row="2" Classes="surface-card section-card log-drawer" IsVisible="{Binding IsLogPanelOpen}">
      <Grid RowDefinitions="Auto,*" RowSpacing="10">
        <TextBlock Classes="title-lg" Text="调试日志"/>
        <ScrollViewer Grid.Row="1" Classes="log-viewer">
          <ItemsControl ItemsSource="{Binding Logs}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:WorkbenchLogEntryViewModel">
                <Grid Margin="0,0,0,8" ColumnDefinitions="70,80,*" ColumnSpacing="10">
                  <TextBlock Classes="caption-soft" Text="{Binding TimeText}"/>
                  <TextBlock Classes="caption-muted" Grid.Column="1" Text="{Binding Category}"/>
                  <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <Border Grid.Row="3" Classes="surface-card section-card" Padding="14,10">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
        <Border Background="#EAF7F0" BorderBrush="#BFE2CC" BorderThickness="1" CornerRadius="999" Padding="14,6">
          <TextBlock Foreground="{DynamicResource SuccessBrush}" Text="{Binding FooterStatusText}"/>
        </Border>
        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding FooterSummary}"/>
        <Button Grid.Column="3" Classes.base-action="True" Content="调试日志" Command="{Binding ToggleLogPanelCommand}"/>
      </Grid>
    </Border>
  </Grid>
</Window>

