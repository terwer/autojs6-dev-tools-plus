<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="App.Avalonia.App"
             xmlns:local="using:App.Avalonia"
             RequestedThemeVariant="Default">

  <Application.DataTemplates>
    <local:ViewLocator/>
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme/>
    <StyleInclude Source="avares://App.Avalonia/Resources/WorkbenchStyles.axaml"/>
  </Application.Styles>
</Application>
